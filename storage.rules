rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de artículos: solo el propio usuario puede subir a su carpeta
    match /items/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Fotos de perfil: solo el propio usuario puede subir a su carpeta
    match /profiles/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
