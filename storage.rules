rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de artículos: solo el propio usuario puede subir a su carpeta;
    // solo imágenes y máximo 5 MB (el cliente ya comprime a ~1200px JPEG)
    match /items/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Fotos de perfil: solo el propio usuario puede subir a su carpeta;
    // solo imágenes y máximo 2 MB (el cliente comprime a 400px)
    match /profiles/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
