rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin real: el flag isAdmin vive en users/{uid} y las propias reglas de
    // users impiden que un usuario se lo asigne a sí mismo
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Perfil de usuario: lectura individual para autenticados (modal de vendedor,
    // botón de WhatsApp); listar la colección completa es solo para admins
    // (evita cosechar teléfonos/correos de toda la comunidad con una cuenta).
    // Nadie puede otorgarse isAdmin: se congela entre escrituras.
    match /users/{userId} {
      allow get: if request.auth != null;
      allow list: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId
        && !('isAdmin' in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false);
    }

    // Artículos: lectura para autenticados (los items históricos guardan
    // teléfono/correo del autor; no exponerlos sin sesión).
    // Update permitido a: el autor (sin reasignar autorId), cualquier usuario
    // que SOLO incremente flagCount en 1 (botón "Reportar"), o un admin.
    match /items/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.autorId == request.auth.uid
        && request.resource.data.titulo is string
        && request.resource.data.titulo.size() > 0
        && request.resource.data.titulo.size() <= 120
        && (request.resource.data.precio == null
            || (request.resource.data.precio is number && request.resource.data.precio >= 0));
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.autorId
          && request.resource.data.autorId == resource.data.autorId)
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flagCount'])
          && request.resource.data.flagCount == resource.data.get('flagCount', 0) + 1)
        || isAdmin()
      );
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.autorId || isAdmin());
    }

    // Alertas: lectura para autenticados (el matching al publicar corre en el
    // cliente del publicador y necesita consultar las alertas activas de todos);
    // escritura solo del dueño
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Chats: solo los participantes. resource == null permite el getDoc previo
    // a crear un chat nuevo (si no, getOrCreateChat falla con permission-denied)
    match /chats/{chatId} {
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
    }

    // Mensajes: solo los participantes del chat padre
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // Notificaciones: el destinatario lee/marca como leído; cualquier usuario
    // autenticado puede crear una notificación para otro usuario (lo requiere el
    // sistema de alertas al publicar), con forma validada para limitar abuso
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId is string
        && request.resource.data.itemId is string
        && request.resource.data.itemTitulo is string
        && request.resource.data.itemTitulo.size() <= 200
        && request.resource.data.leido == false;
    }

    // Reportes de artículos: cada usuario reporta un item una sola vez
    // (id = uid_itemId); solo admins los leen o limpian
    match /flags/{flagId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && flagId == request.auth.uid + '_' + request.resource.data.itemId;
      allow read, delete: if isAdmin();
    }

    // Reseñas de vendedores: lectura para usuarios autenticados; cada comprador
    // escribe una sola reseña por vendedor (id = buyerId_sellerId), sin
    // auto-reseñas y con rating válido de 1 a 5
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.sellerId != request.auth.uid
        && reviewId == request.auth.uid + '_' + request.resource.data.sellerId
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow delete: if request.auth != null && request.auth.uid == resource.data.buyerId;
    }

    // Peones (mano de obra): lectura para autenticados (las publicaciones
    // incluyen teléfono de contacto); solo el propio usuario crea/edita/borra
    match /peones/{peonId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.autorId == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.autorId;
    }
  }
}
