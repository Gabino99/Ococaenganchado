rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario: cualquier usuario autenticado puede leerlo (el modal de
    // vendedor y el botón de WhatsApp necesitan nombre/teléfono de otros usuarios);
    // solo el propio usuario puede escribirlo
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Artículos: cualquiera puede leer; solo usuarios autenticados pueden crear/editar/borrar
    match /items/{itemId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.autorId == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.autorId;
    }

    // Alertas: solo el propio usuario
    match /alerts/{alertId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Chats: solo los participantes
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
    }

    // Mensajes: solo los participantes del chat padre
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // Notificaciones: el destinatario lee/marca como leído; cualquier usuario autenticado
    // puede crear una notificación para otro usuario (lo requiere el sistema de alertas
    // al publicar un artículo que hace match con la alerta de otra persona)
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Reseñas de vendedores: lectura para usuarios autenticados; cada comprador
    // escribe una sola reseña por vendedor (id = buyerId_sellerId), sin auto-reseñas
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.sellerId != request.auth.uid
        && reviewId == request.auth.uid + '_' + request.resource.data.sellerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.buyerId;
    }

    // Peones (mano de obra): cualquiera puede leer; solo el propio usuario crea/edita/borra lo suyo
    match /peones/{peonId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.autorId == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.autorId;
    }
  }
}
